# ─── AI Sales OS — Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in your values.

# OpenAI-compatible API key (required for post-call AI summaries)
# Works with: OpenAI, Groq, Together, OpenRouter, Azure, etc.
OPENAI_API_KEY=

# (Optional) Override base URL for non-OpenAI providers:
# Groq:      https://api.groq.com/openai/v1
# Together:  https://api.together.xyz/v1
# OpenRouter: https://openrouter.ai/api/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# (Optional) Model to use. Default: gpt-4o-mini
# Groq fast+cheap: llama-3.3-70b-versatile
# OPENAI_MODEL=gpt-4o-mini
